NODE_ENV=development
# Backend (and Swagger at /api/docs) run on this port. Use 3001 so frontend can use 3000.
PORT=3001

MONGODB_URI=mongodb://localhost:27017/yallacphq

# Use a long random secret (>= 32 chars)
JWT_SECRET=change_me_change_me_change_me_change_me
JWT_EXPIRES_IN=15m

LOG_LEVEL=debug

# AWS S3 for image uploads (course images, profile images, bank transfer receipts)
# Uploads work with "Block public access" enabled (no ACL is set).
# For public image URLs, add a bucket policy allowing GetObject on your bucket.
AWS_REGION=eu-north-1
AWS_ACCESS_KEY=your-access-key
AWS_SECRET_KEY=your-secret-key
AWS_BUCKET_NAME=medicova-shop

# Optional: seed admin account (npm run seed). Defaults: admin@example.com / Admin123!
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=Admin123!
# ADMIN_NAME=Admin

# PayPal (server-side capture on confirm).
# On http://localhost use SANDBOX credentials and PAYPAL_API_BASE=https://api.sandbox.paypal.com.
# Live credentials are for production domains only; PayPal may block or reject localhost with live keys.
# PAYPAL_CLIENT_ID=
# PAYPAL_SECRET=
# Production: PAYPAL_API_BASE=https://api.paypal.com
# Local / sandbox: PAYPAL_API_BASE=https://api.sandbox.paypal.com

