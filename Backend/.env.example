NODE_ENV=development
# Backend (and Swagger at /api/docs) run on this port. Use 3001 so frontend can use 3000.
PORT=3001

MONGODB_URI=mongodb://localhost:27017/yallacphq

# Use a long random secret (>= 32 chars)
JWT_SECRET=change_me_change_me_change_me_change_me
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

LOG_LEVEL=debug

# Frontend origin used in verification/reset/payment emails
FRONTEND_URL=http://localhost:3000

# SMTP / email delivery
# Gmail example:
# SMTP_TRANSPORT="smtps://your-email@gmail.com:app-password@smtp.gmail.com"
# SMTP_DEMO_EMAIL=your-email@gmail.com

# AWS S3 for image uploads (course images, profile images, bank transfer receipts)
# Uploads work with "Block public access" enabled (no ACL is set).
# For public image URLs, add a bucket policy allowing GetObject on your bucket.
AWS_REGION=eu-north-1
AWS_ACCESS_KEY=your-access-key
AWS_SECRET_KEY=your-secret-key
AWS_BUCKET_NAME=medicova-shop

# Optional: seed admin account (npm run seed). Defaults: admin@example.com / Admin123!
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=Admin123!
# ADMIN_NAME=Admin

# PayPal (server-side capture on confirm).
# Live on localhost: use live Client ID + Secret, do NOT set PAYPAL_API_BASE (defaults to production).
# In PayPal Developer Dashboard → Your app → Live → Add "Return URL": http://localhost:3000/checkout/paypal-return
# and ensure your app allows the origins you use (e.g. http://localhost:3000).
# PAYPAL_CLIENT_ID=<live-client-id>
# PAYPAL_SECRET=<live-secret>
# Optional: PAYPAL_API_BASE=https://api.paypal.com  (default; use only sandbox for testing: https://api.sandbox.paypal.com)

# Paymob (optional – required when using Paymob at checkout).
# Required: PAYMOB_SECRET_KEY, PAYMOB_HMAC_SECRET, PAYMOB_PUBLIC_KEY, PAYMOB_INTEGRATION_ID, PAYMOB_CALLBACK_URL
# Get keys from Paymob dashboard. In Paymob set Notification URL to: {BACKEND_URL}/api/v1/payment/paymob/callback
# PAYMOB_SECRET_KEY=your-secret-key
# PAYMOB_HMAC_SECRET=your-hmac-secret
# PAYMOB_PUBLIC_KEY=your-public-key
# PAYMOB_INTEGRATION_ID=5514087
# PAYMOB_CALLBACK_URL=https://your-backend-domain.com/api/v1/payment/paymob/callback
# Currency that your Integration ID supports (check Paymob Developers → Payment Integrations). Usually EGP.
# PAYMOB_CURRENCY=EGP
# If Paymob charges 100x the expected amount, set to true (sends amount in EGP instead of piastres).
# PAYMOB_AMOUNT_IN_MAIN_UNIT=false
# Optional: ewallet (e.g. 5514086), Accept Kiosk – all use same PAYMOB_CURRENCY
# PAYMOB_EWALLET_INTEGRATION_ID=5514086
# PAYMOB_KIOSK_INTEGRATION_ID=
# PAYMOB_BASE_URL=https://accept.paymob.com
# PAYMOB_UNIFIED_CHECKOUT_BASE_URL=https://accept.paymob.com
# PAYMOB_SUCCESS_REDIRECT_URL=https://your-frontend.com/dashboard/orders?from=paymob
# PAYMOB_SKIP_HMAC_VERIFICATION=false

