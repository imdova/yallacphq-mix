# Copy to `.env.local` for local development.

# Required for signing auth session cookies (used when BACKEND_URL is not set).
AUTH_SECRET="change-me-long-random-string"

# Backend REST API (for auth and API proxy). When set, login/signup/me use the backend.
# Example: http://localhost:4000 (run Backend on a different port than Next.js)
BACKEND_URL=
# Alternative: NEXT_PUBLIC_API_URL (exposed to client if needed for direct calls)
NEXT_PUBLIC_API_URL=

# Production / optional
DATABASE_URL=
JWT_SECRET=
PAYPAL_SECRET=
GOOGLE_SHEETS_WEBHOOK_URL=

# App origin for server-side API calls (used by lib/api/client.ts on the server).
APP_URL="http://localhost:3000"
# Optional alternative
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# n8n webhook endpoint for marketing lead capture routes.
N8N_WEBHOOK_URL=""

# Public client-side keys (safe to expose)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=""

